# ============================================================
# KONFIGURASI ENVIRONMENT BACKEND VIPIZZA
# ============================================================
# Salin file ini menjadi .env lalu isi nilainya.
# Atau set sebagai Environment Variable di Windows.
# ============================================================

# --- Database MySQL (XAMPP) ---
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=vipizza

# --- Server ---
PORT=8080

# --- Notifikasi WhatsApp (pilih salah satu) ---

# OPSI 1: Fonnte (disarankan) - daftar di https://fonnte.com
FONNTE_TOKEN=
ADMIN_WA=6281234567890

# OPSI 2: CallMeBot (gratis) - daftar di https://www.callmebot.com
# CALLMEBOT_APIKEY=

# --- Midtrans (Payment Gateway) ---
# Daftar akun Sandbox di https://simulator.sandbox.midtrans.com/ atau https://dashboard.midtrans.com/
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_ENVIRONMENT=sandbox # sandbox atau production
